---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Invitación Baby Shower - Juan Martín | ¡Acompáñanos en este gran día!",
	description = "Te invitamos cordialmente al Baby Shower de Juan Martín. Juan Pablo Plaza y Diana Velasquez te esperan para compartir esta alegría y amor."
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/webp" href="/favicon.webp" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://invitacion-baby-shower-juan-martin.vercel.app/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://invitacion-baby-shower-juan-martin.vercel.app/hero.webp" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://invitacion-baby-shower-juan-martin.vercel.app/" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content="https://invitacion-baby-shower-juan-martin.vercel.app/hero.webp" />

		<!-- Apple Touch Icon -->
		<link rel="apple-touch-icon" href="/favicon.webp" />
	</head>
	<body class="selection:bg-baby-green selection:text-white overflow-x-hidden relative bg-baby-green-light">
		<!-- Subtle Background Pattern -->
		<div class="fixed inset-0 pointer-events-none opacity-[0.22] z-0" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='200' height='200' viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%23166534' stroke-width='1.6'%3E%3C!-- R1, C1: Tetero --%3E%3Cg transform='translate(50,50)'%3E%3Cpath d='M-8 0h16v18c0 3-4 3-8 3s-8 0-8-3V0zM-5 0l2-8h6l2 8M-8 4h16M-8 8h16'/%3E%3C/g%3E%3C!-- R1, C2: Pelota de Futbol --%3E%3Cg transform='translate(150,50)'%3E%3Ccircle r='12'/%3E%3Cpath d='M0-5 l4.7 3.4 -1.8 5.6 h-5.8 l-1.8 -5.6 z'/%3E%3Cpath d='M0-5 v-7 M4.7-1.6 l6-3 M2.9 4 l5 6 M-2.9 4 l-5 6 M-4.7-1.6 l-6-3'/%3E%3C/g%3E%3C!-- R2, C1 (Staggered): Panal --%3E%3Cg transform='translate(100,150)'%3E%3Cpath d='M-14 -4 h28 v3 h-28 z'/%3E%3Cpath d='M-14 -1 c0 10 4 15 14 15 s14-5 14-15h-28z'/%3E%3Cpath d='M-10 -4 l-4 2 M10 -4 l4 2'/%3E%3C/g%3E%3C!-- R2, C2 (Staggered): Chupete --%3E%3Cg transform='translate(0,150)'%3E%3Ccircle r='6'/%3E%3Cpath d='M-7 -5a10 10 0 0 1 14 0M0 6v6a5 5 0 0 1-10 0v-6'/%3E%3C/g%3E%3Cg transform='translate(200,150)'%3E%3Ccircle r='6'/%3E%3Cpath d='M-7 -5a10 10 0 0 1 14 0M0 6v6a5 5 0 0 1-10 0v-6'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;); background-repeat: repeat;"></div>
		
		<div class="relative z-10">
			<slot />
		</div>

		<script>
			import { gsap } from "gsap";
			import { ScrollTrigger } from "gsap/ScrollTrigger";

			gsap.registerPlugin(ScrollTrigger);

			// Init global animations on load
			window.addEventListener('DOMContentLoaded', () => {
				// Smooth entrance for sections that might not have custom GSAP
				gsap.utils.toArray('section').forEach((section: any) => {
					gsap.from(section, {
						opacity: 0,
						y: 50,
						duration: 1.2,
						ease: "power2.out",
						scrollTrigger: {
							trigger: section,
							start: "top 85%",
							toggleActions: "play none none reverse"
						}
					});
				});
			});
		</script>
	</body>
</html>

<style is:global>
	:root {
		--glass-bg: rgba(255, 255, 255, 0.7);
		--glass-border: rgba(255, 255, 255, 0.4);
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		scroll-behavior: smooth;
	}

	.glass {
		background: var(--glass-bg);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid var(--glass-border);
	}
</style>
