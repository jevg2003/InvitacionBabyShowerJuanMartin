---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero/Hero.astro';
import Intro from '../components/Intro/Intro.astro';
import Info from '../components/Info/Info.astro';
import Gifts from '../components/Gifts/Gifts.astro';
import RSVP from '../components/RSVP/RSVP.astro';
---

<Layout>
	<main class="active-animations">
		<Hero />
		<Intro />
		<Info />
		<Gifts />
		<RSVP />
	</main>

	<footer class="py-12 bg-baby-blue-light text-center">
		<p class="font-accent text-2xl text-baby-blue-dark">¡Te esperamos, Juan Martín!</p>
		<p class="text-slate-400 text-xs mt-4 uppercase tracking-[0.2em] font-body">Diseñado con amor para la familia Plaza Velasquez</p>
	</footer>
</Layout>

<style is:global>
	/* Global fade-in for sections */
	section {
		opacity: 1;
	}
	
	@media (prefers-reduced-motion: no-preference) {
		.active-animations section {
			animation: reveal-section both;
			animation-timeline: view();
			animation-range: entry 10% cover 30%;
		}
	}

	@keyframes reveal-section {
		from {
			opacity: 0;
			transform: scale(0.95) translateY(50px);
		}
		to {
			opacity: 1;
			transform: scale(1) translateY(0);
		}
	}
</style>
