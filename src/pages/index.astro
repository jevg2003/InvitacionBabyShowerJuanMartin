---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero/Hero.astro';
import Intro from '../components/Intro/Intro.astro';
import Info from '../components/Info/Info.astro';
import Gifts from '../components/Gifts/Gifts.astro';
import RSVP from '../components/RSVP/RSVP.astro';
---

<Layout>
	<main class="active-animations">
		<Hero />
		<Intro />
		<Info />
		<Gifts />
		<RSVP />
	</main>

	<footer class="py-16 bg-gradient-to-b from-baby-blue-light to-slate-50 text-center relative">
		<p class="font-accent text-4xl text-baby-blue-dark mb-4 drop-shadow-sm">¡Te esperamos, Juan Martín!</p>
		<p class="text-slate-400 text-[10px] mt-2 mb-10 uppercase tracking-[0.2em] font-body font-bold">Diseñado con amor para la familia Plaza Velasquez</p>

		<!-- Developer Promotion -->
		<div class="mt-8 pt-8 border-t border-slate-200/60 max-w-2xl mx-auto flex flex-col items-center justify-center relative z-10">
			<div class="bg-white/60 backdrop-blur-sm border border-white p-6 rounded-3xl shadow-sm hover:shadow-xl hover:shadow-slate-200/50 transition-all duration-500 w-full md:w-auto">
				<p class="text-xs text-slate-500 font-bold uppercase tracking-widest mb-2 font-heading">¿Te gustó esta invitación?</p>
				<p class="text-sm text-slate-500 font-light max-w-sm mx-auto mb-5 leading-relaxed">
					Haz que tu próximo evento sea inolvidable con una invitación digital interactiva. ¡Escríbeme!
				</p>
				
				<div class="flex flex-col sm:flex-row items-center justify-center gap-3">
					<a href="https://wa.me/573114687079" target="_blank" class="w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 bg-[#25D366]/10 text-[#25D366] hover:bg-[#25D366] hover:text-white rounded-2xl transition-all duration-300 font-bold group">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.888-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
						<span class="tracking-wide">+57 311 468 7079</span>
					</a>
					<a href="mailto:jevgdg@gmail.com" class="w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 bg-slate-100 text-slate-600 hover:bg-baby-blue hover:text-white rounded-2xl transition-all duration-300 font-bold">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
						</svg>
						<span>jevgdg@gmail.com</span>
					</a>
				</div>
			</div>
		</div>
	</footer>
</Layout>

<style is:global>
	/* Global fade-in for sections */
	section {
		opacity: 1;
	}
	
	@media (prefers-reduced-motion: no-preference) {
		.active-animations section {
			animation: reveal-section both;
			animation-timeline: view();
			animation-range: entry 10% cover 30%;
		}
	}

	@keyframes reveal-section {
		from {
			opacity: 0;
			transform: scale(0.95) translateY(50px);
		}
		to {
			opacity: 1;
			transform: scale(1) translateY(0);
		}
	}
</style>
