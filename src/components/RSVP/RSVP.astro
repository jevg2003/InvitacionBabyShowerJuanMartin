---
const contact = {
  deadline: "Domingo 26 de Abril"
};
---
<section id="rsvp" class="py-32 bg-baby-green-dark text-white text-center relative overflow-hidden">
  <!-- Cinematic Background Elements -->
  <div class="absolute inset-0">
    <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_50%_50%,rgba(255,255,255,0.1),transparent)]"></div>
    <div class="parallax-element pointer-events-none absolute -top-20 -left-20 w-96 h-96 bg-white/5 rounded-full blur-[100px]" data-speed="0.1"></div>
    <div class="parallax-element pointer-events-none absolute -bottom-20 -right-20 w-96 h-96 bg-white/5 rounded-full blur-[100px]" data-speed="0.2"></div>
  </div>

  <div class="container mx-auto px-4 max-w-2xl relative z-10">
    <div class="rsvp-content opacity-0">
      <h2 class="font-heading text-6xl font-black mb-8 tracking-tighter">¡Te Esperamos!</h2>
      
      <!-- Thank you message container -->
      <div class="bg-white/10 backdrop-blur-xl border border-white/20 p-10 md:p-12 rounded-[2.5rem] mb-12 relative overflow-hidden group">
        <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
        
        <p class="text-3xl md:text-4xl text-white font-accent leading-relaxed mb-8 relative z-10">
          "¡Gracias por ser parte de este dulce camino! Tu amor y compañía son el regalo más valioso para nuestra familia."
        </p>
        
        <div class="h-px w-24 bg-white/20 mx-auto mb-8 relative z-10"></div>
        
        <p class="text-xl text-baby-green-light/80 leading-relaxed font-light mb-8 relative z-10">
          No vemos la hora de celebrar juntos la llegada de <span class="text-white font-bold">Juan Martín</span>.
        </p>

        <div class="inline-block px-6 py-2 rounded-full bg-white/5 border border-white/10 text-xs uppercase tracking-[0.3em] font-bold text-baby-green-light/60 relative z-10">
            Confirmar antes del {contact.deadline}
        </div>
      </div>

      <!-- Final sign-off -->
      <p class="text-baby-green-light font-bold uppercase tracking-widest text-sm animate-pulse-slow">
        ¡ESTAMOS ANSIOSOS POR VERTE!
      </p>
    </div>
  </div>
</section>

<style>
  .animate-pulse-slow {
    animation: pulse-slow 3s infinite ease-in-out;
  }
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initRSVP() {
    gsap.to(".rsvp-content", {
      opacity: 1,
      y: 0,
      scale: 1,
      duration: 0.8,
      startAt: { y: 30, scale: 0.98 },
      scrollTrigger: {
        trigger: "#rsvp",
        start: "top 85%",
        toggleActions: "play none none none"
      }
    });
  }

  window.addEventListener('load', initRSVP);
  document.addEventListener('astro:page-load', initRSVP);
</script>
