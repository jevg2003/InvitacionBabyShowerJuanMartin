---
const family = {
  father: "Juan Pablo Plaza",
  mother: "Diana Velasquez",
  sister: "Luciana Plaza"
};
---
<section class="py-32 bg-white relative overflow-hidden">
  <div class="container mx-auto px-4 max-w-4xl text-center relative z-10">
    <div class="intro-content opacity-0">
      <div class="mb-16">
        <div class="intro-icon-wrapper mb-8">
          <svg class="w-20 h-20 mx-auto text-baby-green opacity-40 group-hover:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
        </div>
        <h3 class="font-accent text-4xl text-baby-green-dark mb-8">¡Nuestra familia crece!</h3>
        <blockquote class="text-2xl text-slate-600 leading-relaxed italic font-light max-w-2xl mx-auto">
          "Luciana está muy emocionada por la llegada de su hermanito. Como padres, nos sentimos inmensamente bendecidos de compartir esta alegría con ustedes por segunda vez."
        </blockquote>
      </div>

      <div class="space-y-12">
        <p class="text-slate-400 uppercase tracking-[0.5em] text-xs font-bold">Con mucha ilusión:</p>
        <div class="flex flex-col items-center justify-center gap-6">
          <div class="text-3xl font-heading font-semibold text-slate-800 border-b-2 border-baby-green/30 pb-2 px-6">
            {family.mother} & {family.father}
          </div>
          <div class="text-baby-green font-accent text-3xl">junto a</div>
          <div class="inline-block">
            <div class="text-4xl font-heading font-black text-baby-green-dark bg-baby-green-light px-12 py-4 rounded-full border border-baby-green/20 shadow-xl shadow-baby-green/10 transform hover:scale-105 transition-transform duration-300">
              {family.sister}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Animated Background Orbs -->
  <div class="orb absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-96 h-96 bg-baby-green/10 rounded-full blur-[120px]"></div>
  <div class="orb absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-96 h-96 bg-baby-green/10 rounded-full blur-[120px]"></div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initIntro() {
    gsap.to(".intro-content", {
      opacity: 1,
      y: 0,
      duration: 1.5,
      startAt: { y: 50 },
      scrollTrigger: {
        trigger: ".intro-content",
        start: "top 85%"
      }
    });

    gsap.to(".orb", {
      x: "random(-20, 20)",
      y: "random(-20, 20)",
      duration: 10,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut"
    });
  }

  window.addEventListener('load', initIntro);
  document.addEventListener('astro:page-load', initIntro);
</script>
