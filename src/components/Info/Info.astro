---
const event = {
  date: "Domingo, 3 de Mayo",
  time: "3:00 PM",
  location: "Barrio Santa Mónica Popular",
  address: "CRA 23 # 33e bis - 19",
  lat: 3.4376422,
  lng: -76.5100149,
  label: "Baby Shower Juan Martín"
};
---
<section id="detalles" class="py-32 bg-baby-green-light relative overflow-hidden scroll-mt-20">
  <!-- Dynamic Background Decoration -->
  <div class="absolute top-0 left-0 w-full h-20 bg-gradient-to-b from-white to-transparent opacity-50"></div>
  <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-baby-green/10 rounded-full blur-[100px]"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center mb-20 info-header opacity-0">
      <h2 class="font-heading text-5xl font-black text-slate-800 mb-6 tracking-tight">Detalles del Evento</h2>
      <div class="flex items-center justify-center gap-3">
        <div class="w-12 h-1 bg-baby-green rounded-full"></div>
        <div class="w-3 h-3 bg-baby-green rounded-full animate-ping"></div>
        <div class="w-12 h-1 bg-baby-green rounded-full"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-6xl mx-auto info-grid">
      <!-- Date Card -->
      <div class="info-card glass p-10 rounded-[3rem] shadow-2xl shadow-baby-green/5 flex flex-col items-center text-center group hover:bg-white transition-all duration-500 opacity-0">
        <div class="w-20 h-20 bg-baby-green/10 rounded-3xl flex items-center justify-center text-baby-green-dark mb-8 group-hover:scale-110 group-hover:bg-baby-green group-hover:text-white transition-all duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h4 class="font-heading text-2xl font-bold text-slate-800 mb-3">Fecha</h4>
        <p class="text-slate-500 font-medium leading-relaxed">{event.date}</p>
      </div>

      <!-- Time Card -->
      <div class="info-card glass p-10 rounded-[3rem] shadow-2xl shadow-baby-green/5 flex flex-col items-center text-center group hover:bg-white transition-all duration-500 opacity-0">
        <div class="w-20 h-20 bg-baby-green/10 rounded-3xl flex items-center justify-center text-baby-green-dark mb-8 group-hover:scale-110 group-hover:bg-baby-green group-hover:text-white transition-all duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h4 class="font-heading text-2xl font-bold text-slate-800 mb-3">Hora</h4>
        <p class="text-slate-500 font-medium leading-relaxed">{event.time}</p>
      </div>

      <!-- Location Card -->
      <div class="info-card glass p-10 rounded-[3rem] shadow-2xl shadow-baby-green/5 flex flex-col items-center text-center group hover:bg-white transition-all duration-500 opacity-0 relative">
        <div class="w-20 h-20 bg-baby-green/10 rounded-3xl flex items-center justify-center text-baby-green-dark mb-8 group-hover:scale-110 group-hover:bg-baby-green group-hover:text-white transition-all duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h4 class="font-heading text-2xl font-bold text-slate-800 mb-3">Lugar</h4>
        <p class="text-slate-500 font-medium leading-relaxed mb-6">{event.location}<br/>{event.address}</p>
        
        <button 
          id="open-map-btn"
          data-lat={event.lat}
          data-lng={event.lng}
          data-label={event.label}
          class="inline-flex items-center bg-baby-green-light text-baby-green-dark px-6 py-3 rounded-2xl font-bold shadow-sm hover:bg-baby-green hover:text-white transition-all duration-300 pointer-events-auto cursor-pointer"
        >
          Ver en Mapa
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Map Selector Overlay -->
  <div id="map-selector-overlay" class="fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[100] pointer-events-none opacity-0 transition-opacity duration-300"></div>
  
  <!-- Map Selector Action Sheet -->
  <div id="map-selector-sheet" class="fixed bottom-0 left-0 w-full bg-white rounded-t-[3rem] z-[101] translate-y-full shadow-[0_-20px_80px_rgba(0,0,0,0.15)] p-8 md:p-12 transition-transform duration-500 max-w-xl mx-auto left-1/2 -translate-x-1/2">
    <div class="w-16 h-1.5 bg-slate-100 rounded-full mx-auto mb-10"></div>
    
    <div class="text-center mb-10">
      <h3 class="font-heading text-3xl font-black text-slate-800 mb-2">¿Cómo quieres llegar?</h3>
      <p class="text-slate-400 font-medium italic">Selecciona tu aplicación favorita</p>
    </div>
    
    <div class="grid grid-cols-1 gap-4 mb-8">
      <button data-app="google" class="map-app-btn flex items-center justify-between p-6 rounded-[2rem] bg-slate-50 hover:bg-baby-green-light transition-all duration-300 group">
        <div class="flex items-center gap-5">
          <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-sm">
            <img src="https://www.google.com/s2/favicons?sz=64&domain=maps.google.com" alt="Google Maps" class="w-8 h-8" />
          </div>
          <span class="font-bold text-lg text-slate-700">Google Maps</span>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-300 group-hover:text-baby-green transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <button data-app="waze" class="map-app-btn flex items-center justify-between p-6 rounded-[2rem] bg-slate-50 hover:bg-baby-green-light transition-all duration-300 group">
        <div class="flex items-center gap-5">
          <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-sm">
            <img src="https://www.google.com/s2/favicons?sz=64&domain=waze.com" alt="Waze" class="w-8 h-8" />
          </div>
          <span class="font-bold text-lg text-slate-700">Waze</span>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-300 group-hover:text-baby-green transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <button data-app="apple" id="apple-maps-btn" class="map-app-btn hidden items-center justify-between p-6 rounded-[2rem] bg-slate-50 hover:bg-baby-green-light transition-all duration-300 group">
        <div class="flex items-center gap-5">
          <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-sm">
            <img src="https://www.google.com/s2/favicons?sz=64&domain=apple.com" alt="Apple Maps" class="w-8 h-8" />
          </div>
          <span class="font-bold text-lg text-slate-700">Apple Maps</span>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-300 group-hover:text-baby-green transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
    
    <button id="close-map-selector" class="w-full py-5 text-slate-400 font-bold hover:text-red-400 transition-colors uppercase tracking-[0.2em] text-xs">
      Cerrar
    </button>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initAnimations() {
    gsap.to(".info-header", {
        opacity: 1,
        y: 0,
        duration: 0.8,
        startAt: { y: 30 },
        scrollTrigger: {
            trigger: ".info-header",
            start: "top 95%"
        }
    });

    gsap.to(".info-card", {
      opacity: 1,
      y: 0,
      scale: 1,
      stagger: 0.05,
      duration: 0.4,
      startAt: { y: 20, scale: 0.98, opacity: 0 },
      scrollTrigger: {
        trigger: ".info-grid",
        start: "top 95%"
      }
    });

    // Map Selector Logic
    const openBtn = document.getElementById('open-map-btn');
    const overlay = document.getElementById('map-selector-overlay');
    const sheet = document.getElementById('map-selector-sheet');
    const closeBtn = document.getElementById('close-map-selector');
    const appBtns = document.querySelectorAll('.map-app-btn');
    const appleBtn = document.getElementById('apple-maps-btn');

    // Detect iOS
    const isIos = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    if (isIos && appleBtn) {
      appleBtn.classList.remove('hidden');
      appleBtn.classList.add('flex');
    }

    function showSelector() {
      overlay.classList.remove('pointer-events-none');
      gsap.to(overlay, { opacity: 1, duration: 0.4, ease: "power2.out" });
      gsap.to(sheet, { y: 0, duration: 0.6, ease: "back.out(1.2)" });
    }

    function hideSelector() {
      overlay.classList.add('pointer-events-none');
      gsap.to(overlay, { opacity: 0, duration: 0.3, ease: "power2.in" });
      gsap.to(sheet, { y: "100%", duration: 0.5, ease: "power2.in" });
    }

    function openMap(app) {
      const lat = openBtn?.getAttribute('data-lat');
      const lng = openBtn?.getAttribute('data-lng');
      const label = openBtn?.getAttribute('data-label');
      
      let url = "";

      switch(app) {
        case 'google':
          url = `https://www.google.com/maps/search/?api=1&query=${lat},${lng}`;
          break;
        case 'waze':
          url = `https://waze.com/ul?ll=${lat},${lng}&navigate=yes`;
          break;
        case 'apple':
          url = `maps://maps.apple.com/?q=${encodeURIComponent(label || '')}&ll=${lat},${lng}`;
          break;
      }

      if (url) {
        window.open(url, '_blank');
        hideSelector();
      }
    }

    if (openBtn) openBtn.onclick = showSelector;
    if (closeBtn) closeBtn.onclick = hideSelector;
    if (overlay) overlay.onclick = hideSelector;

    appBtns.forEach(btn => {
      btn.onclick = () => openMap(btn.getAttribute('data-app'));
    });
  }

  // Handle both standard load and Astro view transitions
  if (document.readyState === 'loading') {
    window.addEventListener('load', initAnimations);
  } else {
    initAnimations();
  }
  document.addEventListener('astro:page-load', initAnimations);
</script>

